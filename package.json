{
  "name": "syncride-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "SyncRide - Real-Time Geospatial Group Coordination for Motorcycle Riders",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:shared": "pnpm --filter shared-types build",
    "build:api": "pnpm build:shared && pnpm --filter api build",
    "build:web": "pnpm build:shared && pnpm --filter web build",
    "lint": "turbo lint",
    "test": "turbo test"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  },
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}

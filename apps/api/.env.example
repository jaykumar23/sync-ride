PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# MongoDB Configuration
# For local MongoDB: mongodb://localhost:27017
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=syncride-dev

# Redis Configuration
# For local Redis: redis://localhost:6379
# For Upstash Redis: rediss://default:password@endpoint.upstash.io:6379
# For Redis Cloud: redis://user:password@endpoint:port
REDIS_URL=redis://localhost:6379
